# FastAPI base URL (no trailing slash). app/api/[...path]/route.ts proxies /api/* to this host.
# Use https:// on Vercel (Railway) so POST is not turned into GET by http→https redirects.
# You may omit the scheme — https:// is added; bare http:// to remote hosts is upgraded to https://.
# Local: optional; defaults to http://127.0.0.1:8000
BACKEND_URL=http://127.0.0.1:8000
