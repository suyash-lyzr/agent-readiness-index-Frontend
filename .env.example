# FastAPI backend base URL (no trailing slash). Next.js rewrites proxy /api/* to this host.
# You may omit https:// — it will be added automatically (e.g. xxx.up.railway.app works).
# Local: optional; defaults to http://127.0.0.1:8000
# Vercel: set to your Railway URL, e.g. https://xxx.up.railway.app
BACKEND_URL=http://127.0.0.1:8000
